{
  "name": "tracker",
  "productName": "Tracker",
  "version": "0.2.0",
  "private": true,
  "description": "Tracker desktop app",
  "type": "module",
  "main": "build/main.js",
  "scripts": {
    "start": "npm run compile && electron .",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null || true",
    "compile": "tsc -p tsconfig.build.json && cp src/server/providers/copilot-wrapper.mjs build/server/providers/ && vite build --config src/renderer/vite.config.ts",
    "dev:renderer": "vite --config src/renderer/vite.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/renderer",
    "test": "vitest run",
    "build": "npm run compile && electron-builder --mac",
    "build:dir": "npm run compile && electron-builder --mac dir",
    "release": "npm run compile && electron-builder --mac --publish always"
  },
  "build": {
    "appId": "com.barrynapier.tracker",
    "productName": "Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": "arm64"
        },
        {
          "target": "zip",
          "arch": "arm64"
        }
      ],
      "category": "public.app-category.developer-tools",
      "type": "development",
      "identity": "Apple Development: barry Napier (7A3BU2H4Z7)"
    },
    "publish": {
      "provider": "github",
      "owner": "barry-napier",
      "repo": "tracker"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^37.0.0",
    "electron-builder": "^26.15.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@github/copilot-sdk": "^1.0.7",
    "@hono/node-server": "^2.0.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.11.2",
    "electron-updater": "^6.8.9",
    "hono": "^4.12.30",
    "node-pty": "^1.1.0",
    "shiki": "^4.3.1"
  },
  "allowScripts": {
    "node-pty@1.1.0": true
  }
}
