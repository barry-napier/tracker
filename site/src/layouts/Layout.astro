---
import { GITHUB_URL, RELEASES_URL } from "../lib/releases";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Tracker",
  description = "Tracker — a local-first mission control for your coding-agent tickets.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;650;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline>
      // Set the color scheme before first paint to avoid a theme flash.
      (() => {
        try {
          const stored = localStorage.getItem("tracker-color-scheme");
          const mode = stored === "light" || stored === "dark" ? stored : "system";
          const dark =
            mode === "dark" ||
            (mode === "system" && matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.setAttribute("data-color-scheme", dark ? "dark" : "light");
        } catch {}
      })();
    </script>
  </head>
  <body>
    <div class="page">
      <nav class="topbar" aria-label="Main">
        <div class="topbar-inner">
          <a href="/" class="brand" aria-label="Tracker home">
            <span class="brand-mark" aria-hidden="true">&#9656;</span>
            Tracker
          </a>
          <div class="topbar-right">
            <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="navlink">GitHub</a>
            <a href="/download" class="nav-cta">Download free</a>
          </div>
        </div>
      </nav>

      <main class="main">
        <slot />
      </main>

      <footer class="footer">
        <div class="footer-inner">
          <p class="footer-copy">
            &copy; {new Date().getFullYear()} Barry Napier · Local-first: your code and data never
            leave your machine.
          </p>
          <div class="footer-right">
            <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={RELEASES_URL} target="_blank" rel="noopener noreferrer">Changelog</a>
            <a href="/download">Download</a>
            <div class="scheme-toggle" role="group" aria-label="Color scheme">
              <button type="button" data-scheme="light">Light</button>
              <button type="button" data-scheme="dark">Dark</button>
              <button type="button" data-scheme="system">Auto</button>
            </div>
          </div>
        </div>
      </footer>
    </div>

    <script>
      const KEY = "tracker-color-scheme";
      const mq = window.matchMedia("(prefers-color-scheme: dark)");
      const buttons = Array.from(
        document.querySelectorAll<HTMLButtonElement>(".scheme-toggle button"),
      );

      const getMode = () => {
        const stored = localStorage.getItem(KEY);
        return stored === "light" || stored === "dark" ? stored : "system";
      };

      const apply = () => {
        const mode = getMode();
        const effective = mode === "system" ? (mq.matches ? "dark" : "light") : mode;
        document.documentElement.setAttribute("data-color-scheme", effective);
        buttons.forEach((b) => b.setAttribute("aria-pressed", String(b.dataset.scheme === mode)));
      };

      buttons.forEach((b) =>
        b.addEventListener("click", () => {
          localStorage.setItem(KEY, b.dataset.scheme!);
          apply();
        }),
      );
      mq.addEventListener("change", () => {
        if (getMode() === "system") apply();
      });
      apply();
    </script>
  </body>
</html>

<style is:global>
  /* Tracker design system — same oc-2 token language as the app
     (src/renderer/styles.css): grey ramps, hairline ring elevation,
     state bg/fg/border triplets. Light default; dark via the
     data-color-scheme attribute set before paint and toggled in the footer. */
  :root {
    --grey-50: #ffffff;
    --grey-100: #fafafa;
    --grey-200: #f2f2f2;
    --grey-300: #eeeeee;
    --grey-400: #dbdbdb;
    --grey-500: #aeaeae;
    --grey-600: #808080;
    --grey-700: #5c5c5c;
    --grey-800: #3a3a3a;
    --grey-900: #2e2e2e;
    --grey-1000: #242424;
    --grey-1100: #161616;
    --grey-1200: #080808;

    --blue-100: #ecf1fe;
    --blue-300: #c3d4fd;
    --blue-400: #a2bcff;
    --blue-500: #7698fd;
    --blue-600: #3b5cf6;
    --blue-700: #3250df;
    --blue-800: #2c47c8;
    --blue-900: #263fa9;
    --blue-1200: #1b2852;
    --yellow-100: #fefaec;
    --yellow-300: #f7e5b5;
    --yellow-500: #f2cf76;
    --yellow-800: #cb9f34;
    --yellow-900: #ac8833;
    --yellow-1200: #4b4025;

    --radius-sm: 4px;
    --radius-md: 6px;
    --radius-lg: 10px;
    --radius-full: 999px;
    --fs-base: 13px;
    --fs-sm: 12px;
    --fs-xs: 11px;
    --font-sans: "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
    --font-mono: ui-monospace, "SF Mono", Menlo, Consolas, monospace;

    color-scheme: light;
    --bg-app: var(--grey-100);
    --surface-sunken: rgba(0, 0, 0, 0.035);
    --surface-raised: var(--grey-50);
    --surface-raised-hover: var(--grey-100);
    --surface-panel: var(--grey-50);
    --text-base: var(--grey-1100);
    --text-muted: var(--grey-700);
    --text-faint: var(--grey-600);
    --text-accent: var(--blue-600);
    --text-accent-hover: var(--blue-700);
    --border-muted: rgba(0, 0, 0, 0.08);
    --border-base: rgba(0, 0, 0, 0.1);
    --border-focus: var(--blue-500);
    --contrast-bg: var(--grey-1000);
    --contrast-fg: var(--grey-50);
    --contrast-muted: rgba(255, 255, 255, 0.65);
    --contrast-faint: rgba(255, 255, 255, 0.45);
    --on-contrast-accent: var(--blue-400);
    --ok-bg: #e7f9ea;
    --ok-fg: #198b43;
    --ok-border: #b8e9c1;
    --warn-bg: var(--yellow-100);
    --warn-fg: var(--yellow-800);
    --warn-border: var(--yellow-300);
    --info-bg: var(--blue-100);
    --info-fg: var(--blue-800);
    --info-border: var(--blue-300);
    --selection: var(--blue-300);
    --shadow-button: 0 0 0 0.5px rgba(0, 0, 0, 0.15), 0 1px 2px rgba(0, 0, 0, 0.05);
    --shadow-primary:
      0 0 0 0.5px rgba(0, 0, 0, 0.25),
      0 1px 2px rgba(0, 0, 0, 0.12),
      0 4px 12px rgba(0, 0, 0, 0.08);
    --shadow-raised: 0 0 0 0.5px rgba(0, 0, 0, 0.1), 0 1px 3px rgba(0, 0, 0, 0.04);
    --shadow-card:
      0 0 0 0.5px rgba(0, 0, 0, 0.12),
      0 2px 6px rgba(0, 0, 0, 0.05),
      0 8px 24px rgba(0, 0, 0, 0.06);
    --shadow-hero:
      0 0 0 0.5px rgba(0, 0, 0, 0.12),
      0 2px 6px rgba(0, 0, 0, 0.05),
      0 16px 48px rgba(0, 0, 0, 0.08);
    --strip-inset: inset 0 0.5px 0 rgba(0, 0, 0, 0.08), inset 0 -0.5px 0 rgba(0, 0, 0, 0.08);
  }

  :root[data-color-scheme="dark"] {
    color-scheme: dark;
    --bg-app: var(--grey-1100);
    --surface-sunken: rgba(255, 255, 255, 0.035);
    --surface-raised: #232323;
    --surface-raised-hover: #282828;
    --surface-panel: #1c1c1c;
    --text-base: #f5f5f5;
    --text-muted: #9e9e9e;
    --text-faint: var(--grey-600);
    --text-accent: var(--blue-500);
    --text-accent-hover: var(--blue-400);
    --border-muted: rgba(255, 255, 255, 0.08);
    --border-base: rgba(255, 255, 255, 0.1);
    --border-focus: var(--blue-500);
    --contrast-bg: #f5f5f5;
    --contrast-fg: var(--grey-1100);
    --contrast-muted: rgba(0, 0, 0, 0.6);
    --contrast-faint: rgba(0, 0, 0, 0.45);
    --on-contrast-accent: var(--blue-700);
    --ok-bg: #12251a;
    --ok-fg: #5bd389;
    --ok-border: #1d4028;
    --warn-bg: var(--yellow-1200);
    --warn-fg: var(--yellow-500);
    --warn-border: #4a3f1d;
    --info-bg: #131c33;
    --info-fg: var(--blue-500);
    --info-border: #263a6b;
    --selection: #263a6b;
    --shadow-button:
      0 -0.5px 0 rgba(255, 255, 255, 0.12) inset,
      0 0 0 0.5px rgba(255, 255, 255, 0.14),
      0 1px 2px rgba(0, 0, 0, 0.4);
    --shadow-primary:
      0 0 0 0.5px rgba(255, 255, 255, 0.2),
      0 1px 2px rgba(0, 0, 0, 0.5),
      0 4px 12px rgba(0, 0, 0, 0.3);
    --shadow-raised:
      0 -0.5px 0 rgba(255, 255, 255, 0.08) inset,
      0 0 0 0.5px rgba(255, 255, 255, 0.1),
      0 1px 3px rgba(0, 0, 0, 0.35);
    --shadow-card:
      0 -0.5px 0 rgba(255, 255, 255, 0.08) inset,
      0 0 0 0.5px rgba(255, 255, 255, 0.12),
      0 2px 6px rgba(0, 0, 0, 0.4),
      0 8px 24px rgba(0, 0, 0, 0.35);
    --shadow-hero:
      0 -0.5px 0 rgba(255, 255, 255, 0.1) inset,
      0 0 0 0.5px rgba(255, 255, 255, 0.12),
      0 2px 6px rgba(0, 0, 0, 0.45),
      0 16px 48px rgba(0, 0, 0, 0.5);
    --strip-inset:
      inset 0 0.5px 0 rgba(255, 255, 255, 0.08), inset 0 -0.5px 0 rgba(255, 255, 255, 0.08);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background: var(--bg-app);
    color: var(--text-base);
    font-family: var(--font-sans);
    font-size: var(--fs-base);
    -webkit-font-smoothing: antialiased;
    text-wrap: pretty;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ::selection {
    background: var(--selection);
  }

  img {
    max-width: 100%;
  }

  :focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 2px;
  }

  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .topbar-inner,
  .footer-inner {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 18px;
    padding-bottom: 18px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.01em;
  }

  .brand-mark {
    width: 22px;
    height: 22px;
    border-radius: var(--radius-md);
    background: var(--contrast-bg);
    display: grid;
    place-items: center;
    color: var(--contrast-fg);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
  }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .navlink {
    color: var(--text-muted);
    font-size: var(--fs-base);
    font-weight: 500;
  }

  .navlink:hover {
    color: var(--text-base);
  }

  .nav-cta {
    color: var(--contrast-fg);
    background: var(--contrast-bg);
    font-size: var(--fs-base);
    font-weight: 500;
    padding: 8px 16px;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-button);
  }

  .nav-cta:hover {
    opacity: 0.9;
  }

  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .footer {
    box-shadow: inset 0 0.5px 0 var(--border-muted);
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-top: 24px;
    padding-bottom: 24px;
  }

  .footer-copy {
    font-size: 12.5px;
    color: var(--text-faint);
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .footer-right > a {
    color: var(--text-muted);
    font-size: 12.5px;
  }

  .footer-right > a:hover {
    color: var(--text-base);
  }

  .scheme-toggle {
    display: flex;
    gap: 2px;
    background: var(--surface-sunken);
    border-radius: var(--radius-full);
    padding: 2px;
  }

  .scheme-toggle button {
    font: 500 11px var(--font-sans);
    letter-spacing: 0.02em;
    cursor: pointer;
    border: none;
    border-radius: var(--radius-full);
    padding: 4px 10px;
    min-height: 24px;
    background: transparent;
    color: var(--text-faint);
  }

  .scheme-toggle button[aria-pressed="true"] {
    background: var(--surface-raised);
    color: var(--text-base);
    box-shadow: var(--shadow-button);
  }

  /* -- shared controls, matching the app's button/chip anatomy -- */

  .btn {
    display: inline-block;
    background: var(--surface-raised);
    border: none;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-button);
    color: var(--text-base);
    font: inherit;
    font-weight: 500;
    padding: 6px 14px;
    cursor: pointer;
  }

  .btn:hover {
    background: var(--surface-raised-hover);
  }

  .btn-contrast {
    background: var(--contrast-bg);
    color: var(--contrast-fg);
  }

  .btn-contrast:hover {
    background: color-mix(in srgb, var(--contrast-bg) 88%, var(--contrast-fg));
  }

  .chip {
    display: inline-block;
    font-size: var(--fs-xs);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    background: var(--surface-sunken);
    color: var(--text-muted);
  }

  .chip-mono {
    font-family: var(--font-mono);
  }

  .chip-warn {
    background: var(--warn-bg);
    color: var(--warn-fg);
  }
</style>
