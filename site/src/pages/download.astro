---
import Layout from "../layouts/Layout.astro";
import { RELEASES_URL } from "../lib/releases";
---

<Layout title="Download — Tracker" description="Download Tracker for macOS.">
  <div class="download-page">
    <h1>Download Tracker</h1>
    <p class="subheading">
      <span id="version-label" class="chip chip-mono">Loading latest release&hellip;</span>
      <a id="changelog-link" href="#" target="_blank" rel="noopener noreferrer" style="display:none">
        View changelog<span aria-hidden="true"> &#8599;</span>
      </a>
    </p>

    <section class="platform">
      <h2>macOS</h2>
      <div class="cards">
        <a class="card" data-asset="arm64.dmg" href={RELEASES_URL}>
          <span class="card-arch">Apple Silicon (arm64)</span>
          <span class="chip chip-mono">.dmg</span>
        </a>
      </div>
      <p class="note">
        <span class="chip chip-warn">unsigned</span>
        On first launch, right-click the app and choose <strong>Open</strong>.
      </p>
    </section>

    <p class="releases-link">
      Looking for older versions? Check the
      <a href={RELEASES_URL} target="_blank" rel="noopener noreferrer">
        GitHub releases page<span aria-hidden="true"> &#8599;</span>
      </a>
    </p>
  </div>
</Layout>

<script>
  import { fetchLatestRelease, RELEASES_URL } from "../lib/releases";

  async function init() {
    const versionLabel = document.getElementById("version-label");
    const cards = document.querySelectorAll<HTMLAnchorElement>(".card");

    try {
      const release = await fetchLatestRelease();
      if (!release?.tag_name) throw new Error("no release");

      if (versionLabel && release.tag_name) {
        versionLabel.textContent = `Latest (${release.tag_name})`;
      }

      const changelogLink = document.getElementById("changelog-link") as HTMLAnchorElement | null;
      if (changelogLink && release.html_url) {
        changelogLink.href = release.html_url;
        changelogLink.style.display = "";
      }

      cards.forEach((card) => {
        const suffix = card.dataset.asset;
        if (!suffix) return;

        const match = (release.assets ?? []).find((a) => a.name.endsWith(`-${suffix}`) || a.name.endsWith(`.${suffix}`) || a.name.endsWith(suffix));
        if (match) {
          card.href = match.browser_download_url;
        } else {
          card.href = RELEASES_URL;
        }
      });
    } catch {
      if (versionLabel) {
        versionLabel.textContent = "No release yet";
      }
      cards.forEach((card) => {
        card.href = RELEASES_URL;
      });
    }
  }

  init();
</script>

<style>
  .download-page {
    width: 100%;
    max-width: 880px;
    margin: 0 auto;
    padding: 72px 24px 96px;
  }

  .download-page > * {
    max-width: 520px;
  }

  h1 {
    font-size: 26px;
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .subheading {
    margin-top: 12px;
    color: var(--text-muted);
    font-size: var(--fs-sm);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .subheading a {
    color: var(--text-accent);
  }

  .subheading a:hover {
    color: var(--text-accent-hover);
  }

  .platform {
    margin-top: 40px;
  }

  .platform h2 {
    font-size: var(--fs-base);
    font-weight: 600;
  }

  .cards {
    margin-top: 12px;
  }

  .card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    background: var(--surface-raised);
    box-shadow: var(--shadow-raised);
  }

  .card:hover {
    background: var(--surface-raised-hover);
  }

  .card-arch {
    font-weight: 500;
    font-size: var(--fs-base);
  }

  .note {
    margin-top: 12px;
    font-size: var(--fs-sm);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .releases-link {
    margin-top: 40px;
    font-size: var(--fs-sm);
    color: var(--text-muted);
  }

  .releases-link a {
    color: var(--text-accent);
  }

  .releases-link a:hover {
    color: var(--text-accent-hover);
  }
</style>

<!-- deployed via git integration -->
