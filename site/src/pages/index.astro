---
import Layout from "../layouts/Layout.astro";
import { GITHUB_URL, RELEASES_URL } from "../lib/releases";
---

<Layout>
  <!-- 1. Hero -->
  <header class="hero">
    <a class="release-pill hero-in hero-d1" href={RELEASES_URL} target="_blank" rel="noopener noreferrer">
      <span class="release-dot" aria-hidden="true"></span>
      v0.2.0 shipped July 2026 &rarr;
    </a>
    <h1 id="headline" class="hero-in hero-d1">
      Run five coding agents at once, without babysitting a single terminal.
    </h1>
    <p class="lede hero-in hero-d2">
      Tracker is a free, open-source macOS board for developers running Claude Code: queue tickets,
      let agents work them in parallel, merge only when the evidence says ready.
    </p>
    <div class="cta-row hero-in hero-d2">
      <a class="btn-primary" href="/download">Download for macOS, free</a>
      <a class="btn-secondary" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">View the source</a>
    </div>
    <p class="trust-line hero-in hero-d2">Open source · MIT · no account · everything runs on your machine</p>
    <div class="hero-shot hero-in hero-d3">
      <img
        src="/board.png"
        alt="Tracker board with tickets across Backlog, Todo, In Progress, Verifying, Human Review, and Done columns"
        width="2880"
        height="1800"
        fetchpriority="high"
      />
    </div>
  </header>

  <!-- 2. Built in public strip -->
  <section class="strip" aria-label="Built in public">
    <div class="strip-inner">
      <p class="strip-label">Built in public, one commit at a time:</p>
      <div class="strip-stats">
        <span><strong>v0.2.0</strong> latest release</span>
        <span><strong>MIT</strong> licensed</span>
        <span><strong>0</strong> accounts, servers, telemetry</span>
        <span><strong>1</strong> ~100&nbsp;MB dmg</span>
      </div>
    </div>
  </section>

  <!-- 3. Problem framing -->
  <section class="problem" aria-label="The problem">
    <p class="kicker">The problem</p>
    <h2>Agents made the typing cheap. Supervision became the bottleneck.</h2>
    <p class="problem-body">
      Three agent sessions in three terminals means a day of alt-tabbing: which one finished, which
      is stuck waiting on you, which quietly failed an hour ago. Tracker turns that into one board
      where every ticket carries its state, its branch, and its evidence.
    </p>
  </section>

  <!-- 4. Benefits -->
  <section class="benefits" aria-label="Benefits">
    <article class="benefit">
      <div class="benefit-copy">
        <p class="kicker">Workflows</p>
        <h2>Agents follow your pipeline, so nothing skips a step</h2>
        <p>
          Draw the stages your tickets run through (research, plan, implement, document) as a visual
          graph, and a validator refuses to publish any workflow that can't prove its own work.
        </p>
        <a class="benefit-link" href={`${GITHUB_URL}#workflows`} target="_blank" rel="noopener noreferrer">How workflows work &rarr;</a>
      </div>
      <div class="benefit-shot">
        <img
          src="/canvas.png"
          alt="Workflow canvas editor with a selected stage, prompt-template inspector, and AI assistant chat"
          loading="lazy"
          width="2880"
          height="1800"
        />
      </div>
    </article>

    <article class="benefit benefit-flip">
      <div class="benefit-copy">
        <p class="kicker">Automations</p>
        <h2>Recurring work files itself while you're in a meeting</h2>
        <p>
          Standing orders file tickets on a schedule from playbooks like Find Critical Bugs and Fix
          Snyk Vulnerabilities, so your agents sweep the codebase without being asked.
        </p>
        <a class="benefit-link" href={`${GITHUB_URL}#automations`} target="_blank" rel="noopener noreferrer">Browse the playbooks &rarr;</a>
      </div>
      <div class="benefit-shot">
        <img
          src="/automations.png"
          alt="Automations view with a weekly changelog automation and six playbook templates"
          loading="lazy"
          width="2880"
          height="1800"
        />
      </div>
    </article>

    <article class="benefit">
      <div class="benefit-copy">
        <p class="kicker">Tickets</p>
        <h2>Every ticket carries its evidence, so review takes minutes</h2>
        <p>
          Acceptance criteria with per-item status, gate results with exit codes, and a replayable
          feed of every agent attempt. You audit the work, not reconstruct it.
        </p>
        <a class="benefit-link" href={`${GITHUB_URL}#tickets`} target="_blank" rel="noopener noreferrer">See a ticket's anatomy &rarr;</a>
      </div>
      <div class="benefit-shot">
        <img
          src="/detail.png"
          alt="Ticket detail with acceptance criteria, activity feed, and run properties"
          loading="lazy"
          width="2880"
          height="1800"
        />
      </div>
    </article>

    <article class="benefit benefit-flip">
      <div class="benefit-copy">
        <p class="kicker">Verification</p>
        <h2>Merge on proof, not vibes</h2>
        <p>
          Before a human ever looks, a gate battery runs check scripts and test suites, records a
          demo video of the feature working, and writes a recap. The review wizard walks you through
          it: merge, bounce, or re-verify.
        </p>
        <a class="benefit-link" href={`${GITHUB_URL}#verification`} target="_blank" rel="noopener noreferrer">What the gates check &rarr;</a>
      </div>
      <div class="benefit-shot benefit-shot-tall">
        <img
          src="/review.png"
          alt="Human Review and Done columns with Verified acceptance-criteria chips"
          loading="lazy"
          width="920"
          height="1120"
        />
      </div>
    </article>
  </section>

  <!-- 5. Also in the box -->
  <section class="extras" aria-label="Also in the box">
    <div class="extras-grid">
      <div class="extra">
        <h3>Team pull-request feed</h3>
        <p>Open PRs across your repos and org in one view: CI status rolled up, saved filter tabs, review without leaving the app.</p>
      </div>
      <div class="extra">
        <h3>Live agent logs</h3>
        <p>Watch any run stream phase by phase, with durations, tool calls, and an attempt picker for history.</p>
      </div>
      <div class="extra">
        <h3>Isolated worktrees</h3>
        <p>Each ticket runs in its own git worktree on its own branch, so concurrent agents never touch each other's changes.</p>
      </div>
      <div class="extra">
        <h3>Browser, terminal, diffs</h3>
        <p>A built-in browser for previews, split-pane terminals, file tree, and per-file diffs: the whole loop in one window.</p>
      </div>
    </div>
  </section>

  <!-- 6. Proof and pricing -->
  <section class="proof" aria-label="Proof and pricing">
    <figure class="quote-card">
      <blockquote>
        "I built Tracker because I was the bottleneck. With gates recording a demo video and running
        the test suite before I ever look, reviewing an agent's ticket went from re-doing the work
        to reading the receipts. Since v0.1.0 the entire app has been built this way; every feature
        on this page went through its own board."
      </blockquote>
      <figcaption>
        <span class="quote-avatar" aria-hidden="true">BN</span>
        <span class="quote-who">
          <strong>Barry Napier</strong>
          <span>Creator &amp; maintainer, dogfooding since day one</span>
        </span>
      </figcaption>
    </figure>
    <div class="pricing-card">
      <p class="pricing-kicker">Pricing</p>
      <p class="pricing-price">$0, forever.</p>
      <p class="pricing-body">
        MIT licensed, no paid tier, no account. You bring the agent subscription you already pay
        for; Tracker makes those minutes productive in parallel.
      </p>
      <div class="pricing-cta">
        <a href="/download">Download for macOS, free</a>
        <p>~100&nbsp;MB dmg · Apple Silicon · no signup</p>
      </div>
    </div>
  </section>

  <!-- 7. FAQ -->
  <section class="faq" aria-label="FAQ">
    <h2>Questions, answered straight</h2>
    <div class="faq-list">
      <details>
        <summary>Where does my code and data go?</summary>
        <p>
          Nowhere. Tracker is a local Electron app with a local SQLite store: tickets, runs, and
          logs live in your app data directory, and agents run with your own provider credentials.
          That means you can point it at private repos without adding a new party to your threat
          model.
        </p>
      </details>
      <details>
        <summary>Which coding agents does it work with?</summary>
        <p>
          Claude Code is fully supported today. GitHub Copilot and Kiro CLI integrations sit behind
          the same provider seam in the codebase, so adding more agents is a plug-in, not a
          re-architecture. You pick the agent per project.
        </p>
      </details>
      <details>
        <summary>Why is the build unsigned?</summary>
        <p>
          It's a young open-source project without an Apple Developer certificate yet. The dmg is
          built in public by a GitHub Actions workflow you can read, from source you can audit, so
          instead of trusting a signature, you can verify the pipeline itself. On first launch,
          right-click the app and choose Open.
        </p>
      </details>
      <details>
        <summary>What does it cost?</summary>
        <p>
          Nothing. MIT licensed, no paid tier, no account. You bring your own agent subscription
          (e.g. Claude), which you'd be paying for anyway; Tracker makes those minutes productive in
          parallel instead of serial.
        </p>
      </details>
      <details>
        <summary>Windows or Linux?</summary>
        <p>
          macOS (Apple Silicon) only for now. The stack is Electron, so other platforms are a
          build-matrix change away; starring the repo or opening an issue is what pushes them up the
          list.
        </p>
      </details>
    </div>
  </section>

  <!-- 8. Final CTA -->
  <section class="final" aria-label="Final call to action">
    <div class="final-box">
      <h2>Put your agents on a board.</h2>
      <p class="final-lede">
        Download it, point it at a repo, queue your first ticket. Five minutes from dmg to board.
      </p>
      <div class="cta-row">
        <a class="btn-primary" href="/download">Download for macOS, free</a>
        <a class="btn-secondary" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">Star on GitHub</a>
      </div>
      <p class="trust-line">~100&nbsp;MB dmg · Apple Silicon · MIT licensed</p>
    </div>
  </section>
</Layout>

<script>
  // Ad-copy match: ?headline=Your+headline (or legacy ?h=) replaces the hero headline.
  const params = new URLSearchParams(window.location.search);
  const h = params.get("headline") ?? params.get("h");
  const el = document.getElementById("headline");
  if (h && el) el.textContent = h;
</script>

<style>
  /* Linear-style staged entrance: blur + rise, staggered per row. */
  .hero-in {
    opacity: 0;
    filter: blur(4px);
    transform: translateY(14px);
    animation: hero-in 0.7s cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
  }

  .hero-d1 { animation-delay: 0.08s; }
  .hero-d2 { animation-delay: 0.18s; }
  .hero-d3 { animation-delay: 0.3s; }

  @keyframes hero-in {
    to {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-in {
      animation: none;
      opacity: 1;
      filter: none;
      transform: none;
    }
  }

  .kicker {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .btn-primary,
  .btn-secondary {
    font-size: 15px;
    font-weight: 500;
    padding: 13px 26px;
    border-radius: var(--radius-md);
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  .btn-primary {
    color: var(--contrast-fg);
    background: var(--contrast-bg);
    box-shadow: var(--shadow-primary);
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-secondary {
    color: var(--text-base);
    background: var(--surface-raised);
    box-shadow: var(--shadow-button);
  }

  .btn-secondary:hover {
    background: var(--surface-raised-hover);
  }

  .trust-line {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--text-faint);
    margin-top: 16px;
  }

  /* -- hero -- */

  .hero {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 56px 24px 0;
    text-align: center;
  }

  .release-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--text-muted);
    background: var(--surface-sunken);
    border-radius: var(--radius-full);
    padding: 5px 14px;
  }

  .release-pill:hover {
    color: var(--text-base);
  }

  .release-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ok-fg);
  }

  .hero h1 {
    font-size: clamp(34px, 6vw, 62px);
    line-height: 1.06;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 24px auto 0;
    max-width: 820px;
  }

  .lede {
    font-size: clamp(16px, 2.2vw, 19px);
    line-height: 1.5;
    color: var(--text-muted);
    max-width: 620px;
    margin: 18px auto 0;
  }

  .hero .cta-row {
    margin-top: 30px;
  }

  .hero-shot {
    margin-top: 44px;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    overflow: hidden;
    background: var(--surface-panel);
    box-shadow: var(--shadow-hero);
  }

  .hero-shot img,
  .benefit-shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* -- built-in-public strip -- */

  .strip {
    background: var(--surface-sunken);
    box-shadow: var(--strip-inset);
  }

  .strip-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 26px 24px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 14px 40px;
  }

  .strip-label {
    font-size: var(--fs-base);
    color: var(--text-muted);
    font-weight: 500;
  }

  .strip-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 28px;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--text-faint);
  }

  .strip-stats strong {
    color: var(--text-base);
    font-weight: 600;
  }

  /* -- problem -- */

  .problem {
    max-width: 760px;
    margin: 0 auto;
    padding: 88px 24px 0;
    text-align: center;
  }

  .problem h2 {
    font-size: clamp(26px, 4vw, 38px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 600;
    margin-top: 14px;
  }

  .problem-body {
    font-size: 16px;
    line-height: 1.6;
    color: var(--text-muted);
    margin: 16px auto 0;
    max-width: 600px;
  }

  /* -- benefits -- */

  .benefits {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 72px 24px 0;
    display: grid;
    gap: 96px;
  }

  .benefit {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 32px 48px;
  }

  .benefit-flip {
    flex-wrap: wrap-reverse;
    flex-direction: row-reverse;
  }

  .benefit-copy {
    flex: 1 1 300px;
    min-width: 280px;
  }

  .benefit-copy h2 {
    font-size: clamp(24px, 3vw, 30px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 600;
    margin-top: 12px;
  }

  .benefit-copy p:not(.kicker) {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-muted);
    margin-top: 12px;
  }

  .benefit-link {
    display: inline-block;
    margin-top: 12px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-accent);
  }

  .benefit-link:hover {
    color: var(--text-accent-hover);
    text-decoration: underline;
  }

  .benefit-shot {
    flex: 2 1 460px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--surface-panel);
    box-shadow: var(--shadow-card);
  }

  .benefit-shot-tall {
    flex: 1 1 320px;
    max-width: 480px;
    margin: 0 auto;
  }

  /* -- extras -- */

  .extras {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 80px 24px 0;
  }

  .extras-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
  }

  .extra {
    border-radius: var(--radius-lg);
    background: var(--surface-panel);
    padding: 20px;
    box-shadow: var(--shadow-raised);
  }

  .extra h3 {
    font-size: 15px;
    font-weight: 600;
  }

  .extra p {
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--text-muted);
    margin-top: 8px;
  }

  /* -- proof and pricing -- */

  .proof {
    width: 100%;
    max-width: 1120px;
    margin: 0 auto;
    padding: 88px 24px 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    align-items: stretch;
  }

  .quote-card {
    border-radius: var(--radius-lg);
    background: var(--surface-panel);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    box-shadow: var(--shadow-card);
  }

  .quote-card blockquote {
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .quote-card figcaption {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .quote-avatar {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-full);
    background: var(--info-bg);
    box-shadow: 0 0 0 0.5px var(--info-border);
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--info-fg);
  }

  .quote-who {
    display: flex;
    flex-direction: column;
  }

  .quote-who strong {
    font-size: 13.5px;
    font-weight: 600;
  }

  .quote-who span {
    font-size: 12.5px;
    color: var(--text-muted);
  }

  .pricing-card {
    border-radius: var(--radius-lg);
    background: var(--contrast-bg);
    color: var(--contrast-fg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    box-shadow: var(--shadow-card);
  }

  .pricing-kicker {
    font-size: var(--fs-xs);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--on-contrast-accent);
  }

  .pricing-price {
    font-size: clamp(30px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .pricing-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--contrast-muted);
  }

  .pricing-cta {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 12px;
  }

  .pricing-cta a {
    color: var(--contrast-bg);
    background: var(--contrast-fg);
    font-size: 14.5px;
    font-weight: 500;
    padding: 12px 24px;
    border-radius: var(--radius-md);
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
  }

  .pricing-cta a:hover {
    opacity: 0.92;
  }

  .pricing-cta p {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--contrast-faint);
    text-align: center;
  }

  /* -- FAQ -- */

  .faq {
    width: 100%;
    max-width: 760px;
    margin: 0 auto;
    padding: 88px 24px 0;
  }

  .faq h2 {
    font-size: clamp(26px, 4vw, 34px);
    letter-spacing: -0.02em;
    font-weight: 600;
    margin-bottom: 22px;
    text-align: center;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .faq details {
    border-radius: var(--radius-lg);
    background: var(--surface-panel);
    padding: 16px 20px;
    box-shadow: var(--shadow-raised);
  }

  .faq summary {
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    list-style-position: inside;
  }

  .faq details p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-muted);
    margin-top: 12px;
  }

  /* -- final CTA -- */

  .final {
    width: 100%;
    max-width: 1120px;
    margin: 64px auto 0;
    padding: 0 24px 72px;
  }

  .final-box {
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--surface-sunken), var(--bg-app) 70%);
    text-align: center;
    padding: clamp(48px, 8vw, 76px) 24px;
    box-shadow: 0 0 0 0.5px var(--border-muted);
  }

  .final-box h2 {
    font-size: clamp(30px, 5vw, 48px);
    letter-spacing: -0.03em;
    font-weight: 700;
  }

  .final-lede {
    font-size: 16px;
    color: var(--text-muted);
    margin: 14px auto 0;
    max-width: 460px;
  }

  .final .cta-row {
    margin-top: 26px;
  }

  .final .trust-line {
    font-size: 11.5px;
  }
</style>
