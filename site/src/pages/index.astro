---
import Layout from "../layouts/Layout.astro";
import { GITHUB_URL, RELEASES_URL } from "../lib/releases";
---

<Layout>
  <!-- 1. Hero -->
  <section class="hero">
    <h1 id="headline" class="hero-in hero-d1">The mission control<br class="hide-mobile" /> for your coding agents.</h1>
    <div class="hero-subrow hero-in hero-d2">
      <p class="lede">
        A free, open-source desktop board: queue tickets, let agents work them
        concurrently, review when the board says it's ready.
      </p>
      <a class="hero-new" href="https://github.com/barry-napier/tracker/releases" target="_blank" rel="noopener noreferrer">
        <span class="chip">New</span> v0.2.0 released <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
    <div class="cta-row hero-in hero-d2">
      <a class="btn btn-contrast" href="/download">Download for macOS — free</a>
      <a class="btn" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">View source</a>
    </div>
    <p class="trust-line hero-in hero-d2">Open source · MIT · everything runs on your machine</p>
    <div class="hero-stage hero-in hero-d3">
      <figure class="shot shot-hero">
        <img src="/board.png" alt="Tracker board with tickets across Backlog, Todo, In Progress, Verifying, Human Review, and Done columns" width="1440" height="900" fetchpriority="high" />
      </figure>
    </div>
  </section>

  <!-- 3. Problem framing -->
  <section class="problem">
    <h2>Agents made the typing cheap. Supervision is now the bottleneck.</h2>
    <p>
      Run three agent sessions in three terminals and you spend the day
      alt-tabbing: which one finished, which one is stuck waiting on you, which
      one quietly failed setup an hour ago. Tracker turns that into a board —
      every ticket carries its state, its branch, and its evidence.
    </p>
  </section>

  <!-- 4. Feature cards -->
  <section class="features">
    <p class="features-kicker">Everything between "queue it" and "merge it"</p>

    <!-- Flagship: workflows -->
    <article class="fcard fcard-large">
      <div class="fcard-copy">
        <span class="chip">Workflows</span>
        <h2>Design how your agents work, on a canvas</h2>
        <p>
          Build the pipeline your tickets run through — research, plan,
          implement, dogfood, document — as a visual graph. Every stage declares
          its contract: the checks it must emit, the artifacts it owes. A
          built-in assistant edits the graph from a sentence, and a validator
          refuses to publish a workflow that can't prove its own work.
        </p>
      </div>
      <figure class="shot">
        <img src="/canvas.png" alt="Workflow canvas editor with a selected stage, prompt-template inspector, and AI assistant chat" width="1440" height="900" loading="lazy" />
      </figure>
    </article>

    <!-- Flagship: automations -->
    <article class="fcard fcard-large">
      <div class="fcard-copy">
        <span class="chip">Automations</span>
        <h2>Put recurring work on autopilot</h2>
        <p>
          Standing orders that file tickets on a schedule — daily, weekly, or on
          demand — from playbook templates like Find Critical Bugs,
          Architectural Cleanup, Living Documentation, and Fix Snyk
          Vulnerabilities. Your agents sweep the codebase while you're in a
          meeting.
        </p>
      </div>
      <figure class="shot">
        <img src="/automations.png" alt="Automations view with a weekly changelog automation and six playbook templates" width="1440" height="900" loading="lazy" />
      </figure>
    </article>

    <!-- Half cards -->
    <div class="fcard-row">
      <article class="fcard">
        <div class="fcard-copy">
          <span class="chip">Tickets</span>
          <h2>Every ticket carries its evidence</h2>
          <p>
            Acceptance criteria with per-item status, gate results with exit
            codes, and an activity feed of every agent attempt — folded,
            replayable, auditable.
          </p>
        </div>
        <figure class="shot">
          <img src="/detail.png" alt="Ticket detail with acceptance criteria, activity feed, and run properties" width="1440" height="900" loading="lazy" />
        </figure>
      </article>

      <article class="fcard">
        <div class="fcard-copy">
          <span class="chip">Verification</span>
          <h2>Merge on proof, not vibes</h2>
          <p>
            A gate battery runs before human review: acceptance-criteria check
            scripts, test suites, a recorded demo video of the feature working,
            and recap docs that explain the change. The review wizard walks you
            through the evidence — merge, bounce, or re-verify.
          </p>
        </div>
        <figure class="shot">
          <img src="/review.png" alt="Human Review and Done columns with Verified acceptance-criteria chips" width="920" height="1120" loading="lazy" />
        </figure>
      </article>
    </div>

    <!-- Mini cards -->
    <div class="fcard-minis">
      <article class="fcard fcard-mini">
        <h3>Team pull-request feed</h3>
        <p>One view of open PRs across your repos and org — CI status rolled up, saved filter tabs, review without leaving the app.</p>
      </article>
      <article class="fcard fcard-mini">
        <h3>Live agent logs</h3>
        <p>Watch any run's full conversation stream phase by phase, with durations, tool calls, and an attempt picker for history.</p>
      </article>
      <article class="fcard fcard-mini">
        <h3>Isolated worktrees</h3>
        <p>Each ticket runs in its own git worktree on its own branch — concurrent agents never touch each other's changes.</p>
      </article>
      <article class="fcard fcard-mini">
        <h3>Browser, terminal, diffs</h3>
        <p>A built-in browser for previews, real split-pane terminals, file tree, and per-file diffs — the whole loop in one window.</p>
      </article>
    </div>
  </section>

  <!-- 5/6. Momentum + mid CTA -->
  <section class="midcta">
    <div class="momentum">
      <span class="chip chip-mono">v0.2.0</span>
      <span>First public release shipped July 2026 — built in public, one commit at a time.</span>
      <a href={RELEASES_URL} target="_blank" rel="noopener noreferrer">Changelog<span aria-hidden="true"> &#8599;</span></a>
    </div>
    <div class="midcta-box">
      <h2>Free. Open source. Yours.</h2>
      <p>No account, no telemetry, no server. Download the app and point it at a repo.</p>
      <a class="btn btn-contrast" href="/download">Download for macOS — free</a>
    </div>
  </section>

  <!-- 7. FAQ -->
  <section class="faq">
    <h2>Questions</h2>
    <details>
      <summary>Where does my code and data go?</summary>
      <p>
        Nowhere. Tracker is a local Electron app with a local SQLite store —
        tickets, runs, and logs live in your app data directory. Agents run on
        your machine with your own provider credentials, which means you can
        point it at private repos without adding a new party to your threat model.
      </p>
    </details>
    <details>
      <summary>Which coding agents does it work with?</summary>
      <p>
        Claude Code is fully supported today; GitHub Copilot and Kiro CLI
        integrations are in the codebase behind the same provider seam, so
        adding more doesn't mean re-architecting — pick the agent per project.
      </p>
    </details>
    <details>
      <summary>Why is the build unsigned?</summary>
      <p>
        It's a young open-source project without an Apple Developer certificate
        yet. The dmg is built in public by a GitHub Actions workflow you can
        read, from source you can audit — on first launch, right-click the app
        and choose Open.
      </p>
    </details>
    <details>
      <summary>What does it cost?</summary>
      <p>
        Nothing. MIT licensed, no paid tier, no account. You bring your own
        agent subscription (e.g. Claude), which you'd be paying for anyway —
        Tracker just makes those minutes productive in parallel.
      </p>
    </details>
    <details>
      <summary>Windows or Linux?</summary>
      <p>
        macOS (Apple Silicon) only for now. The stack is Electron, so other
        platforms are a build-matrix change away — star the repo or open an
        issue to push them up the list.
      </p>
    </details>
  </section>

  <!-- 8. Final CTA -->
  <section class="final">
    <h2>Put your agents on a board.</h2>
    <a class="btn btn-contrast" href="/download">Download for macOS — free</a>
    <p class="final-sub">~100&nbsp;MB dmg · Apple Silicon · MIT licensed</p>
  </section>
</Layout>

<script>
  // Ad-copy match: ?h=Your+headline replaces the hero headline.
  const h = new URLSearchParams(window.location.search).get("h");
  const el = document.getElementById("headline");
  if (h && el) el.textContent = h;
</script>

<style>
  section {
    margin-top: 96px;
  }

  section:first-child {
    margin-top: 0;
  }

  /* Linear-style staged entrance: blur + rise, staggered per row. */
  .hero-in {
    opacity: 0;
    filter: blur(4px);
    transform: translateY(14px);
    animation: hero-in 0.7s cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
  }

  .hero-d1 { animation-delay: 0.08s; }
  .hero-d2 { animation-delay: 0.18s; }
  .hero-d3 { animation-delay: 0.3s; }

  @keyframes hero-in {
    to {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-in {
      animation: none;
      opacity: 1;
      filter: none;
      transform: none;
    }
  }

  .hero-subrow {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
  }

  .hero-new {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-sm);
    color: var(--text-muted);
    white-space: nowrap;
  }

  .hero-new:hover {
    color: var(--text-base);
  }

  /* Staged product shot with a floor glow under it, Linear-style. */
  .hero-stage {
    position: relative;
    margin-top: 48px;
  }

  .hero-stage .shot {
    margin-top: 0;
  }

  @media (max-width: 720px) {
    .hero-subrow {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }

    .hide-mobile {
      display: none;
    }
  }

  h1 {
    max-width: 760px;
    font-size: clamp(32px, 6.5vw, 56px);
    line-height: 1.06;
    font-weight: 650;
    letter-spacing: -0.03em;
  }

  h2 {
    font-size: 20px;
    font-weight: 650;
    letter-spacing: -0.01em;
  }

  .lede {
    max-width: 560px;
    margin-top: 16px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .cta-row {
    margin-top: 28px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .trust-line {
    margin-top: 14px;
    font-size: var(--fs-sm);
    color: var(--text-faint);
  }

  .shot {
    margin: 40px 0 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-floating);
    background: var(--surface-raised);
  }

  .shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  .problem {
    max-width: 620px;
  }

  .problem p {
    margin-top: 12px;
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-muted);
  }

  /* Cursor-style feature cards: raised surfaces, chip label, claim, visual. */
  .features-kicker {
    font-size: var(--fs-sm);
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .fcard {
    margin-top: 20px;
    background: var(--surface-raised);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-raised);
    padding: 28px;
    overflow: hidden;
  }

  .fcard:first-of-type {
    margin-top: 24px;
  }

  .fcard-copy {
    max-width: 560px;
  }

  .fcard-copy .chip {
    margin-bottom: 12px;
  }

  .fcard-copy h2 {
    margin-top: 10px;
  }

  .fcard-copy p {
    margin-top: 10px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .fcard .shot {
    margin-top: 24px;
    box-shadow: var(--shadow-floating);
  }

  .fcard-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 20px;
  }

  .fcard-row .fcard {
    margin-top: 0;
    display: flex;
    flex-direction: column;
  }

  .fcard-row .shot {
    margin-top: auto;
    padding-top: 24px;
    background: transparent;
    box-shadow: none;
  }

  .fcard-row .shot img {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-floating);
  }

  .fcard-minis {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
    margin-top: 20px;
  }

  .fcard-mini {
    margin-top: 0;
    padding: 20px;
  }

  .fcard-mini h3 {
    font-size: var(--fs-base);
    font-weight: 600;
  }

  .fcard-mini p {
    margin-top: 8px;
    font-size: var(--fs-sm);
    line-height: 1.55;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .fcard-minis {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .fcard-row,
    .fcard-minis {
      grid-template-columns: 1fr;
    }
  }

  .momentum {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    font-size: var(--fs-sm);
    color: var(--text-muted);
  }

  .momentum a {
    color: var(--text-accent);
  }

  .momentum a:hover {
    color: var(--text-accent-hover);
  }

  .midcta-box {
    margin-top: 24px;
    background: var(--surface-raised);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-raised);
    padding: 28px;
  }

  .midcta-box p {
    margin: 8px 0 18px;
    font-size: 14px;
    color: var(--text-muted);
  }

  .faq details {
    margin-top: 10px;
    background: var(--surface-raised);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-raised);
    padding: 12px 16px;
  }

  .faq details:first-of-type {
    margin-top: 20px;
  }

  .faq summary {
    cursor: pointer;
    font-weight: 500;
    font-size: var(--fs-base);
  }

  .faq details p {
    margin-top: 10px;
    font-size: var(--fs-base);
    line-height: 1.6;
    color: var(--text-muted);
  }

  .final {
    text-align: center;
    padding: 48px 0 16px;
  }

  .final .btn {
    margin-top: 20px;
  }

  .final-sub {
    margin-top: 12px;
    font-size: var(--fs-sm);
    color: var(--text-faint);
  }
</style>
