---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <p class="wordmark" aria-hidden="true">tracker</p>

  <section class="hero">
    <h1>Ship tickets while agents do the typing.</h1>
    <p class="lede">
      Tracker is a local-first desktop board for coding-agent work. Queue tickets,
      run concurrent agent sessions, watch the logs, and merge when it's green —
      all from one window.
    </p>
    <div class="cta-row">
      <a class="btn btn-contrast" href="/download">Download for macOS</a>
      <a class="btn" href="https://github.com/barry-napier/tracker" target="_blank" rel="noopener noreferrer">View source</a>
    </div>
  </section>

  <section class="features">
    <div class="feature">
      <span class="chip">Board</span>
      <h2>Board-first workflow</h2>
      <p>Kanban columns that mirror the real lifecycle of agent work — queued, running, waiting on you, parked, done.</p>
    </div>
    <div class="feature">
      <span class="chip">Sessions</span>
      <h2>Concurrent sessions</h2>
      <p>Multiple tickets in flight at once, each in its own isolated session with its own logs and diffs.</p>
    </div>
    <div class="feature">
      <span class="chip">Local</span>
      <h2>Local and private</h2>
      <p>Everything runs on your machine. Your code, your keys, your data — nothing leaves the laptop.</p>
    </div>
  </section>
</Layout>

<style>
  /* Same treatment as the app's home/boot-splash wordmark. */
  .wordmark {
    font-size: clamp(4rem, 14vw, 8rem);
    margin: 0 0 48px;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(to bottom, var(--text-faint), color-mix(in srgb, var(--text-faint) 35%, transparent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    opacity: 0.5;
    user-select: none;
  }

  .hero {
    max-width: 600px;
  }

  h1 {
    font-size: 34px;
    line-height: 1.15;
    font-weight: 650;
    letter-spacing: -0.02em;
  }

  .lede {
    margin-top: 16px;
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .cta-row {
    margin-top: 28px;
    display: flex;
    gap: 10px;
  }

  .features {
    margin-top: 80px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .feature {
    background: var(--surface-raised);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-raised);
    padding: 16px;
  }

  .feature h2 {
    margin-top: 10px;
    font-size: var(--fs-base);
    font-weight: 600;
  }

  .feature p {
    margin-top: 6px;
    font-size: var(--fs-sm);
    line-height: 1.55;
    color: var(--text-muted);
  }

  @media (max-width: 720px) {
    h1 {
      font-size: 28px;
    }
    .features {
      grid-template-columns: 1fr;
    }
  }
</style>
