{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "renderer",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev:renderer"
      ],
      "port": 5199,
      "autoPort": true
    },
    {
      "name": "site",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--prefix",
        "site"
      ],
      "port": 4173,
      "autoPort": true
    },
    {
      "name": "api",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--experimental-transform-types",
        "scripts/dev-api.ts"
      ],
      "port": 4400,
      "autoPort": true
    }
  ]
}